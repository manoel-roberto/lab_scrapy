# DOE-BA Intelligence Engine - Environment Variables
# 
# NOTA TÉCNICA: Este arquivo (.env.example) serve apenas como modelo.
# NUNCA versione o arquivo .env real contendo credenciais ou segredos.
# Para configurar seu ambiente, copie este arquivo: cp .env.example .env

# Banco de Dados (PostgreSQL + pgvector)
DATABASE_URL=postgresql://user:password@localhost:5432/doe_ba

# Inteligência Artificial (Ollama Local)
OLLAMA_HOST=http://localhost:11434

# Configurações do Worker
POLLING_INTERVAL=3600

# Observabilidade
LOG_LEVEL=INFO
